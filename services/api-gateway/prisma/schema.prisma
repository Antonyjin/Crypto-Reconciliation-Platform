generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Trade {
  id         String   @id @default(uuid())
  externalId String     
  exchange   String
  baseAsset  String
  quoteAsset String
  side       String
  amount     String
  price      String
  fee        String?
  feeAsset   String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([externalId, exchange])
}
